rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user logged in?
    function toAuthent() {
      return request.auth != null;
    }

    // Helper: Does the user own the document?
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 1. Users collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Sub-collections under users (bookings, chat_history, notifications, favorites, itineraries)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Destinations collection rules (read-only for all logged-in users, write for bootstrapping)
    match /destinations/{destId} {
      allow read, write: if toAuthent();
    }

    // 3. Hotels collection rules (read-only for all logged-in users, write for bootstrapping)
    match /hotels/{hotelId} {
      allow read, write: if toAuthent();
    }

    // 4. Reviews collection rules (users can add reviews, only owner can edit/delete)
    match /reviews/{reviewId} {
      allow read: if toAuthent();
      allow create: if toAuthent() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if toAuthent() && resource.data.userId == request.auth.uid;
    }

    // 5. Global bookings collection rules (users can write bookings, only owner can read)
    match /bookings/{bookingId} {
      allow create: if toAuthent();
      allow read, update, delete: if toAuthent() && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
